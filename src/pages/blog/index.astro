---
import Layout from '../../layouts/Layout.astro';
import BrandMark from '../../components/site/BrandMark.astro';
import SiteFooter from '../../components/site/SiteFooter.astro';
import '../../styles/global.css';

// Newest first. Add new posts to the top of this list.
const posts = [
  {
    slug: '/blog/how-to-make-chat-story-videos-for-tiktok',
    title: 'How to make chat story videos for TikTok, Reels & Shorts',
    description:
      'Complete guide to creating animated texting story videos for TikTok, Instagram Reels and YouTube Shorts — free, no watermark. Script, export and post in under 10 minutes.',
    dateLabel: 'July 19, 2026',
    readingTime: '7 min read',
    image: '/landing/banner-chatstory.png',
  },
  {
    slug: '/blog/how-to-make-a-fake-whatsapp-chat',
    title: 'How to make a fake WhatsApp chat (2026 guide)',
    description:
      'Create a realistic WhatsApp chat screenshot or animated video in under two minutes — free, no signup, no watermark. Group chats, reactions, typing bubbles and more.',
    dateLabel: 'July 13, 2026',
    readingTime: '6 min read',
    image: '/blog/whatsapp-chat-example.webp',
  },
];
---
<Layout
  title="Blog — Easy Chat Maker"
  description="Guides and ideas for making chat mockups, chat story videos and fake conversation screenshots — WhatsApp, Instagram, ChatGPT and more."
>
  <div class="min-h-screen bg-gradient-to-br from-[#0A0A1A] via-[#10172b] to-[#16213E] text-white">
    <header class="mx-auto flex max-w-6xl items-center justify-between px-5 py-5">
      <BrandMark />
      <a
        href="/editor"
        class="rounded-xl bg-white/10 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-white/15"
      >
        Open the editor
      </a>
    </header>

    <main class="mx-auto max-w-3xl px-5 pb-24 pt-8">
      <h1 class="text-[34px] font-bold leading-tight md:text-[42px]">Blog</h1>
      <p class="mt-3 text-[15px] leading-relaxed text-white/55">
        Guides and ideas for chat mockups, chat-story videos and fictional conversation screenshots.
      </p>

      <div class="mt-10 space-y-6">
        {posts.map((post) => (
          <a
            href={post.slug}
            class="group flex flex-col gap-5 rounded-2xl border border-white/15 bg-white/[0.03] p-5 transition-colors hover:border-[#60efff]/30 hover:bg-white/[0.05] sm:flex-row"
          >
            <img
              src={post.image}
              alt=""
              loading="lazy"
              class="h-40 w-full flex-shrink-0 rounded-xl border border-white/15 object-cover object-top sm:h-32 sm:w-40"
            />
            <div class="min-w-0">
              <h2 class="text-[19px] font-bold leading-snug text-white/90 transition-colors group-hover:text-white">
                {post.title}
              </h2>
              <p class="mt-2 text-[14px] leading-relaxed text-white/55">{post.description}</p>
              <p class="mt-3 text-[12.5px] text-white/35">{post.dateLabel} · {post.readingTime}</p>
            </div>
          </a>
        ))}
      </div>
    </main>

    <SiteFooter />
  </div>
</Layout>
