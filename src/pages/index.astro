      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.on { opacity: 1; transform: none; }

    /* AI card demo loop: welcome -> prompt -> thinking -> response */
    .ai-demo-welcome { animation: ai-welcome 6s ease infinite; }
    .ai-demo-user { animation: ai-user 6s ease infinite; }
    .ai-demo-dot { animation: ai-dot 6s ease infinite; }
    .ai-demo-resp { animation: ai-resp 6s ease infinite; }
    @keyframes ai-welcome {
      0%, 18% { opacity: 1; }
      26%, 92% { opacity: 0; }
      100% { opacity: 1; }
    }
    @keyframes ai-user {
      0%, 24% { opacity: 0; transform: translateY(8px); }
      30%, 88% { opacity: 1; transform: none; }
      94%, 100% { opacity: 0; }
    }
    @keyframes ai-dot {
      0%, 32% { opacity: 0; }
      38% { opacity: 1; }
      44% { opacity: 0.35; }
      50% { opacity: 1; }
      56% { opacity: 0.35; }
      60%, 100% { opacity: 0; }
    }
    @keyframes ai-resp {
      0%, 60% { opacity: 0; transform: translateY(8px); }
      66%, 88% { opacity: 1; transform: none; }
      94%, 100% { opacity: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .ai-demo-welcome { display: none; animation: none; }
      .ai-demo-user, .ai-demo-dot, .ai-demo-resp { animation: none; opacity: 1; }
      .ai-demo-dot { display: none; }
    }

    /* Step 3 export demo: cursor clicks PNG, then Video */
    .step-cursor { animation: step-cursor 7s ease-in-out infinite; left: 30%; top: 30%; }
    .step-btn-png { animation: step-click-png 7s ease-in-out infinite; transform-origin: center; }
    .step-btn-vid { animation: step-click-vid 7s ease-in-out infinite; transform-origin: center; }
    .step-progress { width: 0; animation: step-progress 7s linear infinite; }
    @keyframes step-cursor {
      0% { left: 62%; top: 78%; }
      16% { left: 24%; top: 34%; }
      24% { left: 24%; top: 34%; }
      48% { left: 68%; top: 34%; }
      58% { left: 68%; top: 34%; }
      100% { left: 62%; top: 78%; }
    }
    @keyframes step-click-png {
      0%, 15%, 25%, 100% { transform: scale(1); filter: none; }
      19% { transform: scale(0.92); filter: brightness(1.25); }
    }
    @keyframes step-click-vid {
      0%, 49%, 60%, 100% { transform: scale(1); filter: none; }
      53% { transform: scale(0.92); filter: brightness(1.25); }
    }
    @keyframes step-progress {
      0%, 53% { width: 0; }
      88%, 96% { width: 100%; }
      100% { width: 100%; }
    }
    @media (prefers-reduced-motion: reduce) {
      .step-cursor { display: none; animation: none; }
      .step-btn-png, .step-btn-vid { animation: none; }
      .step-progress { animation: none; width: 100%; }
    }

    /* Step 2 demo: cursor clicks the avatar, profile picture changes */
    .edit-cursor { animation: edit-cursor 7s ease-in-out infinite; left: 70%; top: 70%; }
    .edit-avatar-1 { animation: edit-avatar-1 7s ease infinite; }
    .edit-avatar-2 { animation: edit-avatar-2 7s ease infinite; }
    @keyframes edit-cursor {
      0% { left: 70%; top: 72%; }
      22% { left: 40px; top: 34px; }
      34% { left: 40px; top: 34px; transform: scale(1); }
      27% { transform: scale(0.8); }
      60% { left: 70%; top: 72%; }
      100% { left: 70%; top: 72%; }
    }
    @keyframes edit-avatar-1 {
      0%, 27% { opacity: 1; transform: scale(1); }
      29% { transform: scale(0.85); }
      33%, 93% { opacity: 0; }
      98%, 100% { opacity: 1; transform: scale(1); }
    }
    @keyframes edit-avatar-2 {
      0%, 27% { opacity: 0; }
      33%, 93% { opacity: 1; }
      98%, 100% { opacity: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .edit-cursor { display: none; animation: none; }
      .edit-avatar-1 { animation: none; opacity: 1; }
      .edit-avatar-2 { animation: none; opacity: 0; }
    }
    .bubble-caret { animation: caret-blink 0.9s step-end infinite; color: #128c7e; }
    @keyframes caret-blink { 50% { opacity: 0; } }
    @media (prefers-reduced-motion: reduce) {
      .marquee-track { animation: none; }
      .reveal { opacity: 1; transform: none; transition: none; }
    }
  </style>

  <script>
    // Scroll progress bar
    const progressBar = document.getElementById('scroll-progress');
    const updateProgress = () => {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const pct = max > 0 ? (window.scrollY / max) * 100 : 0;
      if (progressBar) progressBar.style.width = pct + '%';
    };
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    // Scroll reveals
    const revealEls = document.querySelectorAll('.reveal');
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) if (e.isIntersecting) { e.target.classList.add('on'); io.unobserve(e.target); }
    }, { threshold: 0.15 });
    revealEls.forEach((el) => io.observe(el));

    // Platform tour: crossfade the sticky phone as beats scroll by
    const beats = document.querySelectorAll('.tour-beat');
    const imgs = document.querySelectorAll('.tour-img');
    const tourIo = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        const idx = e.target.getAttribute('data-tour');
        imgs.forEach((img) => {
          img.classList.toggle('opacity-100', img.getAttribute('data-tour-img') === idx);
          img.classList.toggle('opacity-0', img.getAttribute('data-tour-img') !== idx);
        });
      }
    }, { threshold: 0.6 });
    beats.forEach((b) => tourIo.observe(b));

    // Bubble editing demo: retype phrases in the self bubble
    const phrases = ['Does 10:30 work?', 'Let’s do 11 instead 😅', 'Actually… brunch?'];
    const target = document.getElementById('bubble-typed');
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (target && !reduced) {
      let pi = 0;
      const type = async () => {
        const word = phrases[pi];
        for (let i = 0; i <= word.length; i++) {
          target.textContent = word.slice(0, i);
          await new Promise((r) => setTimeout(r, 55));
        }
        await new Promise((r) => setTimeout(r, 1600));
        for (let i = word.length; i >= 0; i--) {
          target.textContent = word.slice(0, i);
          await new Promise((r) => setTimeout(r, 25));
        }
        pi = (pi + 1) % phrases.length;
        type();
      };
      type();
    } else if (target) {
      target.textContent = phrases[0];
    }
  </script>
</Layout>
