---
import Layout from '../layouts/Layout.astro';
import { HomeHeroPhone } from '../components/home/HomeHeroPhone';
import SiteFooter from '../components/site/SiteFooter.astro';
import '../styles/global.css';

const platforms = [
  { id: 'whatsapp', name: 'WhatsApp-style', color: '#25D366', viewBox: '0 0 24 24', icon: '<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" /><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.553 4.116 1.523 5.847L.057 23.054a.5.5 0 0 0 .61.637l5.39-1.41A11.943 11.943 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.85 0-3.59-.5-5.09-1.373l-.365-.216-3.791.994.997-3.69-.23-.38A9.957 9.957 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z" />' },
  { id: 'instagram', name: 'Instagram DM', color: '#E1306C', viewBox: '0 0 24 24', icon: '<rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="2.2" /><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2.2" /><circle cx="17.25" cy="6.75" r="1.25" />' },
  { id: 'messenger', name: 'Messenger', color: '#0084FF', viewBox: '0 0 24 24', icon: '<path d="M12 2C6.35 2 2 6.13 2 11.7c0 2.9 1.19 5.4 3.12 7.11v3.01c0 .43.5.67.84.41l2.67-2.03c1.04.29 2.17.44 3.37.44 5.65 0 10-4.13 10-9.7S17.65 2 12 2Zm1.03 12.83-2.55-2.72-4.98 2.72 5.48-5.82 2.61 2.72 4.91-2.72-5.47 5.82Z" />' },
  { id: 'telegram', name: 'Telegram', color: '#2AABEE', viewBox: '0 0 24 24', icon: '<path d="M21.82 4.07 18.64 19.1c-.24 1.06-.86 1.32-1.74.82l-4.83-3.56-2.33 2.24c-.26.26-.47.47-.97.47l.35-4.91 8.94-8.08c.39-.35-.08-.54-.6-.19L6.41 12.85l-4.76-1.49c-1.03-.32-1.05-1.03.22-1.53L20.5 2.65c.86-.32 1.61.19 1.32 1.42Z" />' },
  { id: 'slack', name: 'Slack', color: '#E01E5A', viewBox: '0 0 28 28', icon: '<path d="M9.05 14.9a2.15 2.15 0 1 1-2.15-2.15h2.15v2.15Z" /><path d="M10.1 14.9a2.15 2.15 0 0 1 4.3 0v5.35a2.15 2.15 0 1 1-4.3 0V14.9Z" /><path d="M13.1 9.05a2.15 2.15 0 1 1 2.15-2.15v2.15H13.1Z" /><path d="M13.1 10.1a2.15 2.15 0 0 1 0 4.3H7.75a2.15 2.15 0 1 1 0-4.3h5.35Z" /><path d="M18.95 13.1a2.15 2.15 0 1 1 2.15 2.15h-2.15V13.1Z" /><path d="M17.9 13.1a2.15 2.15 0 0 1-4.3 0V7.75a2.15 2.15 0 1 1 4.3 0v5.35Z" /><path d="M14.9 18.95a2.15 2.15 0 1 1-2.15 2.15v-2.15h2.15Z" /><path d="M14.9 17.9a2.15 2.15 0 0 1 0-4.3h5.35a2.15 2.15 0 1 1 0 4.3H14.9Z" />' },
  { id: 'discord', name: 'Discord', color: '#5865F2', viewBox: '0 0 24 24', icon: '<path d="M19.55 5.03A17.18 17.18 0 0 0 15.24 3.7a.07.07 0 0 0-.08.04c-.18.32-.39.74-.53 1.07a15.9 15.9 0 0 0-4.8 0 10.7 10.7 0 0 0-.54-1.07.08.08 0 0 0-.08-.04c-1.5.25-2.95.7-4.31 1.33a.06.06 0 0 0-.03.03C2.13 9.15 1.39 13.14 1.76 17.08c0 .02.01.04.03.05a17.3 17.3 0 0 0 5.29 2.67.08.08 0 0 0 .09-.03c.41-.56.77-1.15 1.08-1.78a.08.08 0 0 0-.04-.1 11.4 11.4 0 0 1-1.66-.79.08.08 0 0 1-.01-.13l.33-.25a.08.08 0 0 1 .08-.01c3.46 1.58 7.19 1.58 10.61 0a.08.08 0 0 1 .08.01l.34.25a.08.08 0 0 1-.01.13c-.53.31-1.08.57-1.66.79a.08.08 0 0 0-.04.11c.32.62.68 1.21 1.08 1.77a.08.08 0 0 0 .09.03 17.25 17.25 0 0 0 5.3-2.67.08.08 0 0 0 .03-.05c.45-4.56-.75-8.51-3.19-12.02a.06.06 0 0 0-.03-.03ZM8.57 14.68c-1.04 0-1.9-.96-1.9-2.14s.84-2.14 1.9-2.14c1.06 0 1.92.97 1.9 2.14 0 1.18-.84 2.14-1.9 2.14Zm6.86 0c-1.04 0-1.9-.96-1.9-2.14s.84-2.14 1.9-2.14c1.06 0 1.92.97 1.9 2.14 0 1.18-.84 2.14-1.9 2.14Z" />' },
  { id: 'chatgpt', name: 'ChatGPT', color: '#10A37F', viewBox: '0 0 24 24', icon: '<path d="M22.28 9.82a5.98 5.98 0 0 0-.52-4.91 6.05 6.05 0 0 0-6.51-2.9A6.07 6.07 0 0 0 4.98 4.18a5.98 5.98 0 0 0-4 2.9 6.05 6.05 0 0 0 .75 7.1 5.98 5.98 0 0 0 .51 4.91 6.05 6.05 0 0 0 6.51 2.9A5.98 5.98 0 0 0 13.26 24a6.06 6.06 0 0 0 5.77-4.21 5.99 5.99 0 0 0 4-2.9 6.06 6.06 0 0 0-.75-7.07zM13.26 22.43c-1.04 0-1.86-.32-2.57-.9l.13-.07 4.27-2.47a.7.7 0 0 0 .35-.6v-6.03l1.8 1.05a.06.06 0 0 1 .04.05v4.99a4.5 4.5 0 0 1-4.02 3.98zm-9.67-4.13a4.47 4.47 0 0 1-.54-3.01l.13.08 4.27 2.46a.7.7 0 0 0 .7 0l5.21-3v2.08a.07.07 0 0 1-.03.06L9.02 19.4a4.5 4.5 0 0 1-5.43-1.1zM2.34 8.44a4.48 4.48 0 0 1 2.37-1.97v5.08a.69.69 0 0 0 .35.6l5.19 3-1.8 1.04a.07.07 0 0 1-.07 0l-4.32-2.49a4.5 4.5 0 0 1-1.72-5.26zm14.82 3.44-5.21-3.02 1.8-1.04a.07.07 0 0 1 .06 0l4.32 2.5a4.49 4.49 0 0 1-.65 8.1v-5.08a.7.7 0 0 0-.32-.46zm1.8-2.71-.13-.08-4.27-2.48a.7.7 0 0 0-.7 0l-5.21 3.01V7.55a.06.06 0 0 1 .03-.06l4.32-2.49a4.5 4.5 0 0 1 6.68 4.66zM8.05 12.86l-1.8-1.04a.06.06 0 0 1-.04-.05V6.78a4.5 4.5 0 0 1 7.37-3.45l-.13.07-4.27 2.47a.7.7 0 0 0-.35.6zm.98-2.11 2.32-1.34 2.33 1.34v2.68l-2.32 1.34-2.33-1.34z" />' },
  { id: 'claude', name: 'Claude', color: '#D97757', viewBox: '0 0 24 24', icon: '<path d="M11.16 2.06c.24-.05.5-.06.74-.01.24.05.42.24.5.47l.86 5.4c.03.2.3.24.4.06l2.71-4.74a.9.9 0 0 1 1.24-.32c.4.23.55.72.36 1.14l-2.28 5.02c-.08.18.11.36.28.27l4.9-2.53a.9.9 0 0 1 1.2.42c.2.42.05.92-.35 1.15l-4.7 2.87c-.17.1-.1.36.1.37l5.46.34c.47.03.83.42.83.89s-.36.86-.83.89l-5.45.34c-.2.01-.27.27-.1.37l4.69 2.86c.4.24.55.74.35 1.16a.9.9 0 0 1-1.2.42l-4.9-2.54c-.17-.09-.36.1-.28.28l2.28 5.02a.9.9 0 0 1-.36 1.14.9.9 0 0 1-1.24-.32l-2.7-4.74c-.1-.18-.38-.13-.41.07l-.86 5.39a.87.87 0 0 1-.87.74.87.87 0 0 1-.87-.74l-.86-5.4c-.03-.2-.3-.24-.4-.06l-2.71 4.74a.9.9 0 0 1-1.24.32.9.9 0 0 1-.36-1.14l2.28-5.02c.08-.18-.11-.37-.28-.28l-4.9 2.54a.9.9 0 0 1-1.2-.42.92.92 0 0 1 .35-1.16l4.69-2.86c.17-.1.1-.36-.1-.37l-5.45-.34a.89.89 0 0 1-.83-.89c0-.47.36-.86.83-.89l5.45-.34c.2-.01.28-.27.1-.37L3.35 8.39a.92.92 0 0 1-.35-1.15.9.9 0 0 1 1.2-.42l4.9 2.53c.17.09.36-.09.28-.27L7.1 4.06a.9.9 0 0 1 .36-1.14.9.9 0 0 1 1.24.32l2.7 4.74c.11.18.38.14.41-.06l.86-5.4a.87.87 0 0 1 .5-.46z" />' },
  { id: 'gemini', name: 'Gemini', color: '#4285F4', viewBox: '0 0 24 24', icon: '<path d="M12 24A14.3 14.3 0 0 0 0 12 14.3 14.3 0 0 0 12 0a14.3 14.3 0 0 0 12 12 14.3 14.3 0 0 0-12 12z" />' },
];

const faqs = [
  {
    q: 'Is it really free?',
    a: 'Yes. Create and export as many chats as you want, free, with no signup and no watermark.',
  },
  {
    q: 'What platforms can I make?',
    a: 'Chats styled like WhatsApp, Instagram DMs, Messenger, Telegram, Slack, Discord, and AI assistants (ChatGPT, Claude and Gemini) — as one-on-one or group conversations.',
  },
  {
    q: 'Can I make a fake ChatGPT, Claude or Gemini conversation?',
    a: 'Yes — pick an AI platform and the editor switches to that assistant’s look, complete with typing animation and response actions. Perfect for demos, decks and content.',
  },
  {
    q: 'Can I use this for testimonials and marketing?',
    a: 'Absolutely. Slack and Discord-style threads work great for B2B social proof, WhatsApp and Instagram styles for mobile-first proof, and AI-chat mockups for product demos — exported as pixel-clean PNGs with no watermark.',
  },
  {
    q: 'Can I make a group chat?',
    a: 'Yes — add any number of people with their own names, avatars, and colors, including members joining mid-conversation.',
  },
  {
    q: 'Does it export video?',
    a: 'You can export a still image or a silent animated clip where messages appear one by one. Add voiceover or captions in your own editor if you need them.',
  },
  {
    q: 'Is this a fake chat generator / chat mockup maker / screenshot creator?',
    a: 'All the same thing — different names people use for this tool. It makes realistic fictional chat images and clips.',
  },
  {
    q: 'Is this legal? Is it affiliated with WhatsApp, Meta, Slack or others?',
    a: 'Creating clearly fictional mockups for content, demos and fun is fine. This is an independent tool, not affiliated with or endorsed by any messaging platform or AI company. Don’t use it to deceive, impersonate, or harm anyone.',
  },
];

const marquee = [
  'chat memes', 'testimonial screenshots', 'product demos', 'chat story videos',
  'pranks', 'tutorials', 'pitch decks', 'social proof', 'storyboards',
];

const softwareLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Easy Chat Maker',
  applicationCategory: 'DesignApplication',
  operatingSystem: 'Web',
  description: 'Free chat mockup generator with no watermark. Create fictional WhatsApp-style, Instagram, Slack, Discord and AI chat conversations and export them as images or animated clips.',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
});

const faqLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});
---
<Layout>
  <script type="application/ld+json" set:html={softwareLd} />
  <script type="application/ld+json" set:html={faqLd} />

  <!-- Scroll progress bar -->
  <div
    id="scroll-progress"
    class="fixed left-0 top-0 z-[100] h-[3px] w-0 bg-gradient-to-r from-[#00FF87] to-[#60EFFF]"
    style="box-shadow: 0 0 12px rgba(0,255,135,0.5)"
  />

  <div class="min-h-screen overflow-x-clip bg-gradient-to-br from-[#0A0A1A] via-[#10172b] to-[#16213E] text-white">
    <!-- Nav -->
    <header class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-5">
      <span class="text-lg font-bold bg-gradient-to-r from-[#00FF87] to-[#60EFFF] bg-clip-text text-transparent whitespace-nowrap">
        Easy Chat Maker
      </span>
      <nav class="hidden items-center gap-1 md:flex" aria-label="Page sections">
        <a href="#how-it-works" class="rounded-lg px-3 py-2 text-sm font-medium text-white/55 transition-colors hover:bg-white/5 hover:text-white">How it works</a>
        <a href="#use-cases" class="rounded-lg px-3 py-2 text-sm font-medium text-white/55 transition-colors hover:bg-white/5 hover:text-white">Use cases</a>
        <a href="#platforms" class="rounded-lg px-3 py-2 text-sm font-medium text-white/55 transition-colors hover:bg-white/5 hover:text-white">Platforms</a>
        <a href="#why" class="rounded-lg px-3 py-2 text-sm font-medium text-white/55 transition-colors hover:bg-white/5 hover:text-white">Why us</a>
        <a href="#faq" class="rounded-lg px-3 py-2 text-sm font-medium text-white/55 transition-colors hover:bg-white/5 hover:text-white">FAQ</a>
      </nav>
      <a
        href="/editor"
        class="rounded-xl bg-white/10 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-white/15 whitespace-nowrap"
      >
        Open the editor
      </a>
    </header>

    <!-- Hero -->
    <section class="relative mx-auto grid max-w-6xl items-center gap-12 px-5 pb-20 pt-10 md:grid-cols-[1.15fr_1fr] md:pt-16">
      <div class="pointer-events-none absolute -left-40 top-10 h-96 w-96 rounded-full bg-[#00FF87]/10 blur-[120px]" />
      <div class="pointer-events-none absolute -right-24 bottom-0 h-80 w-80 rounded-full bg-[#60EFFF]/10 blur-[120px]" />

      <div class="relative">
        <h1 class="text-[42px] font-extrabold leading-[1.08] md:text-[62px]">
          Create realistic<br />chat mockups
          <span class="bg-gradient-to-r from-[#00FF87] to-[#60EFFF] bg-clip-text text-transparent">in seconds</span>
        </h1>
        <p class="mt-6 max-w-md text-[17px] leading-relaxed text-white/65">
          A free fake chat generator for WhatsApp, Instagram, Slack, Discord — and AI chats
          like ChatGPT, Claude and Gemini. No signup. No watermark.
        </p>
        <div class="mt-8">
          <a
            href="/editor"
            class="inline-block rounded-2xl bg-gradient-to-r from-[#00FF87] to-[#60EFFF] px-8 py-4 text-[15px] font-bold text-[#061116] transition-all hover:brightness-110"
          >
            Make a chat — free
          </a>
        </div>
        <p class="mt-5 text-[12.5px] text-white/35">
          Runs in your browser. For mockups, content and fun — not affiliated with any app.
        </p>
      </div>

      <div class="relative mx-auto">
        <HomeHeroPhone client:load />
      </div>
    </section>

    <!-- Marquee -->
    <div class="border-y border-white/5 bg-white/[0.02] py-4">
      <div class="marquee">
        <div class="marquee-track">
          {[...marquee, ...marquee].map((item) => (
            <span class="mx-6 inline-flex items-center gap-3 text-[14px] font-medium text-white/40">
              <span class="h-1.5 w-1.5 rounded-full bg-gradient-to-r from-[#00FF87] to-[#60EFFF]" />
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- How it works -->
    <section id="how-it-works" class="mx-auto max-w-6xl scroll-mt-6 px-5 py-24">
      <div class="reveal flex justify-center">
        <span class="rounded-full border border-white/15 bg-white/[0.06] px-4 py-1.5 text-[13px] font-semibold text-white/70">How it works</span>
      </div>
      <h2 class="reveal mt-5 text-center text-[34px] font-bold md:text-[44px]">
        3 easy steps to a <span class="bg-gradient-to-r from-[#00FF87] to-[#60EFFF] bg-clip-text text-transparent">realistic chat</span>
      </h2>
      <p class="reveal mx-auto mt-4 max-w-xl text-center text-[16.5px] leading-relaxed text-white/55">
        Write it, style it, ship it — from idea to a share-ready image or clip in under a
        minute. No design skills, no signup.
      </p>

      <div class="mt-14 grid gap-5 md:grid-cols-3">

        <!-- Step 1: paste a script -->
        <div class="reveal rounded-3xl border border-white/10 bg-white/[0.03] p-7">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-white/[0.07] text-[15px] font-extrabold text-[#00FF87]">1</span>
            <h3 class="text-[19px] font-bold">Paste a script</h3>
          </div>
          <p class="mt-2.5 text-[14.5px] leading-relaxed text-white/60">
            Write your conversation as simple <span class="text-white/80">Name: message</span> lines
            and the whole thread builds itself — or start empty and add bubbles one by one.
          </p>
          <div class="mt-6 rounded-2xl border border-white/10 bg-[#0b1220] p-4 font-mono text-[13px] leading-[26px]">
            <div><span class="text-[#00FF87]">Maria:</span> <span class="text-white/85">Boarding now ✈️</span></div>
            <div><span class="text-[#60EFFF]">You:</span> <span class="text-white/85">Send pics!!</span></div>
            <div><span class="text-[#00FF87]">Maria:</span> <span class="text-white/60">[image]</span></div>
            <div><span class="text-[#60EFFF]">You:</span> <span class="text-white/85">Have the best time ❤️</span><span class="bubble-caret text-[#00FF87]">|</span></div>
            <div class="mt-3 rounded-lg bg-gradient-to-r from-[#00FF87] to-[#60EFFF] py-2 text-center font-sans text-[12.5px] font-bold text-[#061116]">Generate chat</div>
          </div>
        </div>

        <!-- Step 2: edit like you're texting -->
        <div class="reveal rounded-3xl border border-white/10 bg-white/[0.03] p-7" style="transition-delay: 0.1s">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-white/[0.07] text-[15px] font-extrabold text-[#00FF87]">2</span>
            <h3 class="text-[19px] font-bold">Edit like you're texting</h3>
          </div>
          <p class="mt-2.5 text-[14.5px] leading-relaxed text-white/60">
            Click any bubble and type. Names, avatars, timestamps and reactions — everything
            is editable right on the phone, and the preview updates as you write.
          </p>
          <div class="relative mt-6 overflow-hidden rounded-2xl bg-[#e5ddd5] p-4">
            <div class="flex items-end justify-start gap-2">
              <span class="relative h-9 w-9 flex-shrink-0">
                <span class="edit-avatar-1 absolute inset-0 flex items-center justify-center rounded-full bg-[#0e9f8a] text-[15px] font-bold text-white">A</span>
                <span class="edit-avatar-2 absolute inset-0 overflow-hidden rounded-full"><img src="/avatar-maria.png" alt="Maria profile photo" width="120" height="120" class="h-full w-full object-cover" loading="lazy" /></span>
              </span>
              <div class="rounded-[8px] rounded-tl-none bg-white px-3 py-2 text-[13.5px] text-[#111] shadow-sm">
                Hey, what time works?
                <span class="ml-2 align-bottom text-[10px] text-[#9aa0a6]">9:41 am</span>
              </div>
            </div>
            <svg class="edit-cursor absolute" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 3l14 8-6.5 1.5L9 19z" fill="#fff" stroke="#000" stroke-width="1.4" />
            </svg>
            <div class="mt-3 flex justify-end">
              <div class="min-w-[175px] rounded-[8px] rounded-tr-none bg-[#d9fdd3] px-3 py-2 text-[13.5px] text-[#111] shadow-sm">
                <span id="bubble-typed"></span><span class="bubble-caret">|</span>
                <span class="ml-2 align-bottom text-[10px] text-[#5f9c58]">9:42 am ✓✓</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3: export -->
        <div class="reveal rounded-3xl border border-white/10 bg-white/[0.03] p-7" style="transition-delay: 0.2s">
          <div class="flex items-center gap-3">
            <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-white/[0.07] text-[15px] font-extrabold text-[#00FF87]">3</span>
            <h3 class="text-[19px] font-bold">Export and share</h3>
          </div>
          <p class="mt-2.5 text-[14.5px] leading-relaxed text-white/60">
            One click for a pixel-clean PNG, another for an animated clip where messages
            appear one by one. No watermark, ready to post.
          </p>
          <div class="relative mt-6 rounded-2xl border border-white/10 bg-[#0b1220] p-5">
            <div class="flex gap-2.5">
              <span class="step-btn-png flex flex-1 items-center justify-center gap-1.5 rounded-xl bg-[#00FF87] py-2.5 text-[13px] font-semibold text-[#061116]">🖼️ Export PNG</span>
              <span class="step-btn-vid flex flex-1 items-center justify-center gap-1.5 rounded-xl bg-[#60EFFF] py-2.5 text-[13px] font-semibold text-[#061116]">🎬 Export Video</span>
            </div>
            <div class="mt-4 h-1.5 w-full overflow-hidden rounded-full bg-white/10">
              <div class="step-progress h-full rounded-full bg-gradient-to-r from-[#00FF87] to-[#60EFFF]"></div>
            </div>
            <div class="mt-2 text-[11.5px] text-white/40">chat-mockup.mp4 — rendering…</div>
            <svg class="step-cursor absolute" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
