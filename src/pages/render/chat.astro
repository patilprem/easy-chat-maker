---
import { RenderChatApp } from '../../components/render/RenderChatApp';
import '../../styles/global.css';
const requestedMode = Astro.url.searchParams.get('mode');
const mode = requestedMode === 'video' ? 'video' : 'export';
const requestedWidth = Number(Astro.url.searchParams.get('w'));
const requestedHeight = Number(Astro.url.searchParams.get('h'));
const fallbackWidth = mode === 'video' ? 390 : 370;
const fallbackHeight = mode === 'video' ? 844 : 824;
const screenWidth = Number.isFinite(requestedWidth) && requestedWidth > 0 ? requestedWidth : fallbackWidth;
const screenHeight = Number.isFinite(requestedHeight) && requestedHeight > 0 ? requestedHeight : fallbackHeight;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content={`width=${screenWidth}, initial-scale=1`} />
    <meta name="robots" content="noindex,nofollow" />
    <title>Render</title>
    <style is:global>
      html,
      body,
      astro-island {
        width: 100%;
        height: 100%;
        overflow: hidden;
      }

      astro-island {
        display: block;
      }
    </style>
  </head>
  <body style="margin:0;padding:0;width:100vw;height:100vh;overflow:hidden;">
    <RenderChatApp client:only="react" mode={mode} />
  </body>
</html>
