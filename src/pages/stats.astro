---
import Layout from '../layouts/Layout.astro';
import BrandMark from '../components/site/BrandMark.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import '../styles/global.css';
---
<Layout title="Export stats — Easy Chat Maker" description="Live counters for chat exports made with Easy Chat Maker.">
  <div class="min-h-screen bg-gradient-to-br from-[#0A0A1A] via-[#10172b] to-[#16213E] text-white">
    <header class="mx-auto flex max-w-6xl items-center justify-between px-5 py-5">
      <BrandMark />
      <a
        href="/editor"
        class="rounded-xl bg-white/10 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-white/15"
      >
        Open the editor
      </a>
    </header>

    <main class="mx-auto max-w-3xl px-5 pb-24 pt-8">
      <h1 class="text-[34px] font-bold leading-tight md:text-[42px]">Export stats</h1>
      <p class="mt-2 text-[13px] text-white/40">
        Live counts of chats exported with Easy Chat Maker. Raw data: <a href="/api/stats" class="text-[#60EFFF] underline underline-offset-2">/api/stats</a>
      </p>

      <div id="stats-error" class="mt-8 hidden rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-sm text-red-400">
        Could not load stats. Try refreshing.
      </div>

      <!-- Stat tiles -->
      <div id="stats-tiles" class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <!-- filled by script -->
      </div>

      <!-- Breakdowns -->
      <div class="mt-10 grid gap-10 sm:grid-cols-2">
        <section>
          <h2 class="text-sm font-semibold uppercase tracking-wide text-white/50">By platform</h2>
          <div id="stats-platforms" class="mt-4 space-y-3"></div>
        </section>
        <section>
          <h2 class="text-sm font-semibold uppercase tracking-wide text-white/50">By day (last 14)</h2>
          <div id="stats-days" class="mt-4 space-y-3"></div>
        </section>
      </div>
    </main>

    <SiteFooter />
  </div>

  <script>
    const fmt = (n: number) => n.toLocaleString('en-US');

    function tile(label: string, value: number): string {
      return `
        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <div class="text-[11px] font-medium uppercase tracking-wide text-white/45">${label}</div>
          <div class="mt-1 text-[26px] font-bold tabular-nums text-white">${fmt(value)}</div>
        </div>`;
    }

    // Single-hue magnitude bars: identity is carried by the row label,
    // the value by bar length plus a direct numeric label.
    function barRow(label: string, value: number, max: number): string {
      const pct = max > 0 ? Math.max(2, Math.round((value / max) * 100)) : 0;
      return `
        <div>
          <div class="flex items-baseline justify-between gap-3">
            <span class="text-[13px] text-white/70">${label}</span>
            <span class="text-[13px] font-semibold tabular-nums text-white">${fmt(value)}</span>
          </div>
          <div class="mt-1 h-2 rounded-full bg-white/10">
            <div class="h-2 rounded-full bg-[#60EFFF]" style="width:${pct}%"></div>
          </div>
        </div>`;
    }

    async function load(): Promise<void> {
      try {
        const res = await fetch('/api/stats');
        if (!res.ok) throw new Error(String(res.status));
        const s = await res.json();
        const byFormat = s.byFormat ?? {};
        const byPlatform = s.byPlatform ?? {};
        const byDay = s.byDay ?? {};
        const today = new Date().toISOString().slice(0, 10);

        document.getElementById('stats-tiles')!.innerHTML = [
          tile('Total exports', s.total ?? 0),
          tile('Videos (MP4)', byFormat.mp4 ?? 0),
          tile('Images (PNG)', byFormat.png ?? 0),
          tile('Today', byDay[today] ?? 0),
        ].join('');

        const platforms = Object.entries(byPlatform).sort((a, b) => (b[1] as number) - (a[1] as number));
        const pMax = Math.max(0, ...platforms.map(([, v]) => v as number));
        document.getElementById('stats-platforms')!.innerHTML = platforms.length
          ? platforms.map(([k, v]) => barRow(k, v as number, pMax)).join('')
          : '<p class="text-[13px] text-white/40">No exports yet.</p>';

        const days = Object.entries(byDay).sort((a, b) => b[0].localeCompare(a[0])).slice(0, 14);
        const dMax = Math.max(0, ...days.map(([, v]) => v as number));
        document.getElementById('stats-days')!.innerHTML = days.length
          ? days.map(([k, v]) => barRow(k, v as number, dMax)).join('')
          : '<p class="text-[13px] text-white/40">No exports yet.</p>';
      } catch {
        document.getElementById('stats-error')!.classList.remove('hidden');
      }
    }

    load();
  </script>
</Layout>
